const { createClient } = require('@supabase/supabase-js');
const twilio = require('twilio');
const { Resend } = require('resend');

module.exports.config = { api: { bodyParser: true } };

module.exports = async function handler(req, res) {
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

  const { worker_id, action } = req.body; // action: 'approve' or 'reject'
  if (!worker_id) return res.status(400).json({ error: 'Missing worker_id' });

  const supabase = createClient(process.env.SUPABASE_URL, process.env.SUPABASE_SERVICE_KEY);
  const resend = new Resend(process.env.RESEND_API_KEY);

  try {
    // Get worker details
    const { data: worker } = await supabase
      .from('workers')
      .select('*')
      .eq('id', worker_id)
      .single();

    if (!worker) return res.status(404).json({ error: 'Worker not found' });

    if (action === 'approve') {
      // Update status to Active
      await supabase
        .from('workers')
        .update({ status: 'Active', updated_at: new Date().toISOString() })
        .eq('id', worker_id);

      // Send SMS via Twilio
      if (process.env.TWILIO_ACCOUNT_SID && worker.phone) {
        try {
          const twilioClient = twilio(process.env.TWILIO_ACCOUNT_SID, process.env.TWILIO_AUTH_TOKEN);
          await twilioClient.messages.create({
            from: process.env.TWILIO_PHONE,
            to: worker.phone,
            body: `🎉 Welcome to ChoreOFF, ${worker.name.split(' ')[0]}! You're approved and ready to work.\n\nLog into the worker portal to start claiming jobs:\nhttps://choreoff.com/worker\n\nQuestions? Email info@choreoff.com`
          });
          console.log('[approve] SMS sent to: ' + worker.phone);
        } catch (smsErr) {
          console.error('[approve] SMS failed:', smsErr.message);
        }
      }

      // Send welcome email
      if (process.env.RESEND_API_KEY && worker.email) {
        try {
          await resend.emails.send({
            from: 'ChoreOFF <info@choreoff.com>',
            to: worker.email,
            subject: "You're approved — welcome to ChoreOFF! 🎉",
            html: `
              <div style="font-family:sans-serif;max-width:560px;margin:0 auto;padding:40px 24px">
                <h2 style="font-size:1.4rem;margin-bottom:8px">You're in, ${worker.name.split(' ')[0]}.</h2>
                <p style="color:#666;margin-bottom:24px">Your ChoreOFF worker account has been approved. You can now log in and start claiming jobs in your area.</p>
                <div style="background:#f5f5f2;border-radius:12px;padding:20px;margin-bottom:24px">
                  <p style="margin:0 0 8px;font-weight:600">Quick reminders:</p>
                  <ul style="margin:0;padding-left:20px;color:#555;font-size:0.9rem;line-height:1.8">
                    <li>$50 per completed job</li>
                    <li>Jobs are first-come, first-served in the portal</li>
                    <li>Full address sent via SMS after you claim</li>
                    <li>Submit completion photo to get paid</li>
                  </ul>
                </div>
                <a href="https://choreoff.com/worker" style="display:inline-block;background:#2ab8b8;color:white;padding:14px 28px;border-radius:100px;text-decoration:none;font-weight:600;font-size:0.95rem">Go to Worker Portal →</a>
                <p style="margin-top:24px;color:#888;font-size:0.85rem">Questions? Reply to this email or follow us @choreoff.us<br>— The ChoreOFF Team</p>
              </div>
            `
          });
          console.log('[approve] Welcome email sent to: ' + worker.email);
        } catch (emailErr) {
          console.error('[approve] Email failed:', emailErr.message);
        }
      }

      return res.status(200).json({ success: true, message: 'Worker approved, SMS and email sent' });

    } else if (action === 'reject') {
      await supabase
        .from('workers')
        .update({ status: 'Inactive', updated_at: new Date().toISOString() })
        .eq('id', worker_id);

      // Send rejection email (optional - polite decline)
      if (process.env.RESEND_API_KEY && worker.email) {
        try {
          await resend.emails.send({
            from: 'ChoreOFF <info@choreoff.com>',
            to: worker.email,
            subject: 'ChoreOFF worker application update',
            html: `
              <div style="font-family:sans-serif;max-width:560px;margin:0 auto;padding:40px 24px">
                <h2 style="font-size:1.4rem;margin-bottom:8px">Hi ${worker.name.split(' ')[0]},</h2>
                <p style="color:#666;margin-bottom:16px">Thank you for applying to work with ChoreOFF.</p>
                <p style="color:#666;margin-bottom:24px">After reviewing your application, we're unable to move forward at this time. We appreciate your interest and wish you the best.</p>
                <p style="color:#888;font-size:0.85rem">— The ChoreOFF Team</p>
              </div>
            `
          });
        } catch(e) {}
      }

      return res.status(200).json({ success: true, message: 'Worker rejected' });
    }

    return res.status(400).json({ error: 'Invalid action' });

  } catch(e) {
    console.error('[approve err]', e.message);
    return res.status(500).json({ error: e.message });
  }
};
